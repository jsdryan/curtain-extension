{
  "manifest_version": 3,
  "name": "Curtain - 隱私簾幕",
  "version": "1.0.0",
  "description": "一鍵隱藏敏感網站的書籤與瀏覽紀錄，需要時再恢復。",
  "permissions": [
    "bookmarks",
    "history",
    "storage",
    "privacy"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
